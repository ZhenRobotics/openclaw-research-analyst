{
  "name": "openclaw-research-analyst",
  "version": "1.2.1",
  "description": "AI-powered stock & crypto research with 8-dimension analysis, portfolio tracking, and trend detection",
  "main": "scripts/stock_analyzer.py",
  "scripts": {
    "analyze": "uv run scripts/stock_analyzer.py",
    "hot": "python3 scripts/trend_scanner.py",
    "rumors": "python3 scripts/rumor_detector.py",
    "dividends": "uv run scripts/dividend_analyzer.py",
    "watchlist": "uv run scripts/watchlist_manager.py",
    "portfolio": "uv run scripts/portfolio_manager.py",
    "test": "uv run pytest scripts/tests.py -v"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZhenRobotics/openclaw-research-analyst.git"
  },
  "keywords": [
    "stock",
    "crypto",
    "analysis",
    "openclaw",
    "portfolio",
    "trading",
    "finance",
    "yfinance",
    "dividend",
    "watchlist",
    "hot-scanner",
    "trend-detection"
  ],
  "author": "ZhenRobotics",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ZhenRobotics/openclaw-research-analyst/issues"
  },
  "homepage": "https://github.com/ZhenRobotics/openclaw-research-analyst#readme",
  "engines": {
    "node": ">=14.0.0",
    "python": ">=3.10"
  },
  "files": [
    "scripts/",
    "docs/",
    "README.md",
    "SKILL.md",
    "INSTALL.md",
    ".env.example",
    "pyproject.toml"
  ]
}
